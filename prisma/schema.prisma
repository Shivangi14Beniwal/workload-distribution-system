generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  leads           Lead[]
  mandatoryRules  MandatoryRule[]
  allocationState AllocationState[]

  createdAt DateTime @default(now())

  @@map("services")
}

model Provider {
  id             String   @id @default(uuid())
  name           String   @unique
  monthlyQuota   Int      @default(10)
  leadsThisMonth Int      @default(0)
  quotaResetAt   DateTime @default(now())

  assignments     LeadAssignment[]
  mandatoryRules  MandatoryRule[]
  allocationState AllocationState[]

  createdAt DateTime @default(now())

  @@map("providers")
}

model Lead {
  id          String @id @default(uuid())
  serviceId   String
  name        String
  phone       String
  city        String
  description String

  service     Service          @relation(fields: [serviceId], references: [id])
  assignments LeadAssignment[]
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())

  @@unique([phone, serviceId])
  @@index([serviceId])
  @@index([createdAt])
  @@map("leads")
}

model LeadAssignment {
  id             String         @id @default(uuid())
  leadId         String
  providerId     String
  assignmentType AssignmentType @default(FAIR_ROTATION)

  lead     Lead     @relation(fields: [leadId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  assignedAt DateTime @default(now())

  @@unique([leadId, providerId])
  @@index([providerId])
  @@index([leadId])
  @@map("lead_assignments")
}

enum AssignmentType {
  MANDATORY
  FAIR_ROTATION
}

model MandatoryRule {
  id         String @id @default(uuid())
  serviceId  String
  providerId String

  service  Service  @relation(fields: [serviceId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@unique([serviceId, providerId])
  @@map("mandatory_rules")
}

model AllocationState {
  id            String @id @default(uuid())
  serviceId     String
  providerId    String
  pointer       Int    @default(0)
  assignedCount Int    @default(0)

  service  Service  @relation(fields: [serviceId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  updatedAt DateTime @updatedAt

  @@unique([serviceId, providerId])
  @@index([serviceId])
  @@map("allocation_state")
}

model WebhookEvent {
  id             String        @id @default(uuid())
  idempotencyKey String        @unique
  eventType      String
  status         WebhookStatus @default(PENDING)
  payload        Json
  responsePayload Json?

  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([idempotencyKey])
  @@index([status])
  @@map("webhook_events")
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

model AuditLog {
  id       String  @id @default(uuid())
  leadId   String?
  action   String
  metadata Json    @default("{}")

  lead Lead? @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())

  @@index([action])
  @@index([leadId])
  @@index([createdAt])
  @@map("audit_logs")
}